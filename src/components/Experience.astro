---
import Container from './primitives/Container.astro';
import SectionEyebrow from './primitives/SectionEyebrow.astro';

const roles = [
  {
    title: 'Care Manager',
    org: 'Elevance Health',
    period: 'Sept 2025 - Present',
    highlights: [
      'Coordinates member assessment and care plan development',
      'Manages resource utilization for appropriate care delivery',
    ],
  },
  {
    title: 'Patient Experience Manager',
    org: 'UNC Health Nash',
    period: 'July 2024 - July 2025',
    highlights: [
      'Led process improvement initiatives based on patient surveys',
      'Analyzed Press Ganey data for units and hospitals',
    ],
  },
  {
    title: 'Health Administrator',
    org: 'Duke Primary Care',
    period: 'Oct 2023 - July 2024',
    highlights: [
      'Directed operational and financial reporting',
      'Led practice process improvement and PDSA projects',
    ],
  },
  {
    title: 'Practice Manager',
    org: 'UNC Physicians Network',
    period: 'Jan 2021 - Oct 2023',
    highlights: [
      'Managed hiring, training, and employee performance',
      'EPIC super user; ensured HIPAA and OSHA compliance',
    ],
  },
  {
    title: 'Care Access Specialist',
    org: 'UNC Physicians Network',
    period: 'Mar 2019 - Jan 2021',
    highlights: [
      'Provided administrative and patient support across practices',
      'Analyzed daily productivity reports for PAC staff',
    ],
  },
];
---

<section class="experience section section--white" id="experience" aria-labelledby="experience-heading">
  <Container>
    <div class="experience__header" data-reveal>
      <SectionEyebrow text="Experience" />
      <h2 id="experience-heading">A career built inside the system</h2>
      <p>
        From phlebotomy and front-office support to practice management and health system
        leadership. Warnetta has worked at every level of healthcare delivery.
      </p>
    </div>

    <ol class="experience__timeline">
      {roles.map((role) => (
        <li class="experience__item" data-reveal>
          <div class="experience__meta">
            <time datetime={role.period}>{role.period}</time>
          </div>
          <div class="experience__body">
            <h3>{role.title}</h3>
            <p class="experience__org">{role.org}</p>
            <ul>
              {role.highlights.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </li>
      ))}
    </ol>
  </Container>
</section>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  .experience__header {
    max-width: 640px;
    margin-bottom: $space-xl;
    display: flex;
    flex-direction: column;
    gap: $space-sm;
  }

  .experience__timeline {
    display: flex;
    flex-direction: column;
    gap: $space-lg;
  }

  .experience__item {
    display: grid;
    gap: $space-sm;
    padding-bottom: $space-lg;
    border-bottom: 1px solid rgba($color-navy, 0.1);

    &:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    @include respond-to(lg) {
      grid-template-columns: 200px 1fr;
      gap: $space-xl;
    }
  }

  .experience__meta time {
    font-size: $font-size-small;
    font-weight: 600;
    color: $color-gold;
    white-space: nowrap;
  }

  .experience__body {
    display: flex;
    flex-direction: column;
    gap: $space-xs;

    h3 {
      font-size: $font-size-h3;
    }
  }

  .experience__org {
    font-weight: 600;
    color: $color-navy;
  }

  .experience__body ul {
    margin-top: $space-xs;
    padding-left: 1.25rem;
    list-style: disc;

    li {
      margin-bottom: 0.25rem;
    }
  }
</style>
