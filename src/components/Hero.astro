---
import { Image } from 'astro:assets';
import Container from './primitives/Container.astro';
import SectionEyebrow from './primitives/SectionEyebrow.astro';
import Button from './primitives/Button.astro';
import headshot from '../assets/warnetta-headshot.jpg';
---

<section class="hero section section--white" aria-labelledby="hero-heading">
  <Container>
    <div class="hero__grid">
      <div class="hero__content">
        <SectionEyebrow text="For better-run healthcare" />
        <h1 id="hero-heading">Healthcare consulting, <strong>made personal.</strong></h1>
        <Button href="#contact" variant="primary">Get in touch</Button>
        <p class="hero__intro">
          Warnetta Wrighton, MHA brings over a decade of healthcare leadership to help providers,
          health systems, and payors improve operations, elevate patient experience, and deliver
          better care across their communities.
        </p>
      </div>

      <div class="hero__visual">
        <div class="hero__headshot-wrap">
          <Image
            src={headshot}
            alt="Warnetta Wrighton, healthcare consultant"
            class="hero__headshot"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 280px, 360px"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </Container>
</section>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  .hero {
    padding-top: $space-sm;
    padding-bottom: $space-lg;

    @include respond-to(md) {
      padding-top: $space-md;
      padding-bottom: $space-xl;
    }

    @include respond-to(lg) {
      padding-block: $space-2xl;
    }
  }

  .hero__grid {
    display: grid;
    gap: $space-lg;
    align-items: center;

    @include respond-to(md) {
      gap: $space-xl;
    }

    @include respond-to(lg) {
      grid-template-columns: 1fr 1fr;
      gap: $space-2xl;
    }
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: $space-md;

    h1 {
      max-width: 16ch;

      strong {
        color: $color-coral;
        font-weight: 600;
      }
    }
  }

  .hero__intro {
    max-width: 52ch;
    font-size: $font-size-body;
  }

  .hero__visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: $space-md;
  }

  .hero__headshot-wrap {
    position: relative;
    width: min(100%, 320px);
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid $color-gold;
    box-shadow: $shadow-card;
    background-color: $color-sand;

    @include respond-to(lg) {
      width: 360px;
    }
  }

  .hero__headshot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
</style>
