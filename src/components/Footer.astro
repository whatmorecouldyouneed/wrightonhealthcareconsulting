---
import Container from './primitives/Container.astro';

const year = new Date().getFullYear();
---

<footer class="footer section section--white">
  <Container>
    <div class="footer__top">
      <div class="footer__brand">
        <span class="footer__logo">Wrighton</span>
        <span class="footer__tagline">Healthcare Consulting</span>
      </div>

      <nav class="footer__nav" aria-label="Footer navigation">
        <ul>
          <li><a href="#about">About</a></li>
          <li><a href="#services">Services</a></li>
          <li><a href="#experience">Experience</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </nav>
    </div>

    <div class="footer__bottom">
      <p class="footer__copy">&copy; {year} Wrighton Healthcare Consulting</p>
      <p class="footer__credit">
        Site by <a href="https://whatmorecouldyouneed.com" target="_blank" rel="noopener noreferrer">WMCYN</a>
      </p>
    </div>
  </Container>
</footer>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  .footer {
    padding-block: $space-xl;
    border-top: 1px solid rgba($color-navy, 0.08);
  }

  .footer__top {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: $space-lg;

    @include respond-to(md) {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: $space-xl;
    }
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer__logo {
    font-family: $font-serif;
    font-size: 1.75rem;
    font-weight: 600;
    color: $color-navy;
  }

  .footer__tagline {
    font-size: $font-size-small;
    color: $color-gold;
    font-weight: 500;
  }

  .footer__nav ul {
    display: flex;
    flex-direction: column;
    gap: $space-sm;

    @include respond-to(md) {
      flex-direction: row;
      gap: $space-lg;
    }

    a {
      font-weight: 500;
      color: $color-navy;
      @include touch-target;
      @include focus-ring;

      &:hover {
        color: $color-coral;
      }
    }
  }

  .footer__bottom {
    margin-top: $space-lg;
    padding-top: $space-md;
    border-top: 1px solid rgba($color-navy, 0.08);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: $space-xs;
    text-align: center;

    @include respond-to(md) {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer__copy,
  .footer__credit {
    font-size: $font-size-small;
    color: $color-slate;
    margin: 0;
  }

  .footer__credit a {
    color: $color-navy;
    font-weight: 600;
    @include focus-ring;

    &:hover {
      color: $color-coral;
    }
  }
</style>
