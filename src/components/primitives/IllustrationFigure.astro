---
import type { ImageMetadata } from 'astro';

interface Props {
  src?: ImageMetadata | string;
  alt?: string;
  class?: string;
}

const { src, alt = '', class: className } = Astro.props;
---

<figure class:list={['illustration-figure', className]}>
  <div class="illustration-figure__dots illustration-figure__dots--left" aria-hidden="true"></div>
  <div class="illustration-figure__circle">
    {src && typeof src === 'string' && src.endsWith('.svg') ? (
      <img src={src} alt={alt} class="illustration-figure__image" loading="lazy" />
    ) : src ? (
      <img src={typeof src === 'string' ? src : (src as ImageMetadata).src} alt={alt} class="illustration-figure__image" loading="lazy" />
    ) : (
      <slot />
    )}
  </div>
  <div class="illustration-figure__dots illustration-figure__dots--right" aria-hidden="true"></div>
</figure>

<style lang="scss">
  @use '../../styles/variables' as *;
  @use '../../styles/mixins' as *;

  .illustration-figure {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 480px;
    margin-inline: auto;
    padding-block: $space-lg;
  }

  .illustration-figure__circle {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(100%, 380px);
    aspect-ratio: 1;
    background-color: rgba($color-sand, 0.8);
    border-radius: 50%;
    padding: $space-md;
  }

  .illustration-figure__image {
    width: 85%;
    height: auto;
    object-fit: contain;
  }

  .illustration-figure__dots {
    position: absolute;
    z-index: 0;
    width: 72px;
    height: 72px;
    background-image: radial-gradient($color-coral 2px, transparent 2px);
    background-size: 12px 12px;
    opacity: 0.55;

    &--left {
      top: 10%;
      left: 0;
    }

    &--right {
      bottom: 10%;
      right: 0;
    }

    @include respond-to(md) {
      width: 96px;
      height: 96px;
    }
  }
</style>
